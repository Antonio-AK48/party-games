# Firebase web app config. Copy this file to .env.local and fill in the values
# from the Firebase console: Project settings → General → Your apps → SDK setup
# and configuration (Config). The databaseURL comes from Realtime Database.
# .env.local is gitignored; never commit real values. Restart `npm run dev`
# after editing, Vite only reads env files at startup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
